# Copy to `server/.env` and fill in. The real .env is gitignored.
# The server loads this via `node --env-file=.env` (see `npm run dev`).

# --- Firebase Admin SDK (used from Phase 4) ---
# Base64 of the service-account JSON. We base64-encode (rather than pasting raw
# JSON) because the JSON's `private_key` has embedded newlines/quotes that get
# mangled differently by shells, dotenv, `node --env-file`, and the CodeSandbox
# env UI. Base64 is one opaque, newline-free token that survives all of them.
# Generate with:  cat service-account.json | base64 | tr -d '\n'
# (firebase.js decodes it back to JSON via Buffer.from(..., "base64").)
FIREBASE_SERVICE_ACCOUNT_B64=
# RTDB URL, e.g. https://xxxx-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=

# --- OpenWeather geocoding (used from Phase 2) ---
ZIP_API_KEY=

# --- HTTP ---
PORT=8080

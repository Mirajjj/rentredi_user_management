# Copy to `client/.env` and fill in. The real .env is gitignored.
# Vite only exposes VITE_-prefixed vars to the browser.

# OPTIONAL. By default the client calls the relative `/api` path, which the Vite
# dev server proxies to the API on :8080 (see vite.config.js). That works both
# locally and on CodeSandbox with no config, so this is usually left unset.
# Set it only to point the client at a different API origin.
# VITE_API_URL=http://localhost:8080

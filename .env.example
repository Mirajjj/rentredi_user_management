# Copy to `.env` at the repo root and fill in. The real .env is gitignored.
# The server reads this file via `node --env-file=../.env`; the client (Vite)
# reads the VITE_-prefixed vars from it via `envDir: ".."`.

# --- Server: Firebase Admin SDK (used from Phase 4) ---
# JSON string of the service-account credentials, on a single line.
FIREBASE_SERVICE_ACCOUNT=
# RTDB URL, e.g. https://xxxx-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=

# --- Server: OpenWeather geocoding (used from Phase 2) ---
ZIP_API_KEY=

# --- Server: HTTP ---
PORT=8080

# --- Client: URL of the server API ---
VITE_API_URL=http://localhost:8080
